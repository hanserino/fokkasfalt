# Copy to ".env" in the project root (gitignored). fetch_episodes.rb loads it automatically.
# PATREON_RSS_URL=https://www.patreon.com/rss/YOUR_PROJECT?auth=YOUR_TOKEN&show=YOUR_SHOW_ID

# Optional: cap items when testing locally (omit in production)
# EPISODE_LIMIT=5

# Optional for scripts/match_episode_availability.rb: episode-spesifikke Spotify-lenker (auto-laster fra .env)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# (Redirect URI i Spotify dashboard teller ikke for dette scriptet — kun client credentials.)
